{
    "semi": true,
    "singleQuote": false,
    "useTabs": true,
    "tabWidth": 4,
    "printWidth": 80,
    "plugins": ["prettier-plugin-sort-imports"],
    "importOrder": [
        "^node:(.*)$",
        "<BUILTIN_MODULES>",
        "<THIRD_PARTY_MODULES>",
        "^[.]"
    ],
    "importOrderTypeScriptVersion": "5.0.0"
}
